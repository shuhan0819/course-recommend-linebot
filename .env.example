# ────────────────────────────────────────────────────────
# 課程推薦聊天機器人 — 環境變數範本
# 複製此檔案為 .env 並填入真實值，.env 已列入 .gitignore
# ────────────────────────────────────────────────────────

# OpenAI API 金鑰
# 用途：驅動 GPT-4o-mini（意圖判斷、課程推薦）與 text-embedding-3-small（向量搜尋）
# 取得：https://platform.openai.com/api-keys
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# LINE Bot Channel Secret
# 用途：驗證 Webhook 請求的簽名，防止偽造請求
# 取得：LINE Developers Console > 你的 Channel > Basic settings > Channel secret
LINE_CHANNEL_SECRET=YOUR_LINE_CHANNEL_SECRET

# LINE Bot Channel Access Token
# 用途：呼叫 LINE Messaging API 回覆使用者訊息
# 取得：LINE Developers Console > 你的 Channel > Messaging API > Channel access token
LINE_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN
